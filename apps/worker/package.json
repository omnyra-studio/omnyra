{
  "name": "@omnyra/worker",
  "version": "0.1.0",
  "private": true,
  "main": "./dist/worker.js",
  "scripts": {
    "build":       "tsc",
    "dev":         "ts-node-dev --respawn --transpile-only src/worker.ts",
    "start":       "node dist/worker.js",
    "worker:start": "node dist/worker.js",
    "typecheck":   "tsc --noEmit"
  },
  "dependencies": {
    "@omnyra/continuity-engine": "*",
    "@omnyra/prompt-engine":     "*",
    "@omnyra/model-router":      "*",
    "@omnyra/memory-system":     "*",
    "bullmq":                    "^5.0.0",
    "ioredis":                   "^5.0.0",
    "@supabase/supabase-js":     "^2.0.0"
  },
  "devDependencies": {
    "typescript":     "^5.0.0",
    "ts-node-dev":    "^2.0.0",
    "@types/node":    "^20.0.0"
  }
}

{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "ANTHROPIC_API_KEY",
    "FAL_KEY",
    "FAL_API_KEY",
    "FALAI_API_KEY",
    "KLING_API_KEY",
    "ELEVENLABS_API_KEY",
    "REDIS_URL",
    "REDIS_HOST",
    "REDIS_PORT",
    "REDIS_PASSWORD",
    "REDIS_TLS",
    "NEXT_PUBLIC_SUPABASE_URL",
    "NEXT_PUBLIC_SUPABASE_ANON_KEY",
    "SUPABASE_SERVICE_ROLE_KEY",
    "ENABLE_AGENT_SWARM",
    "NODE_ENV"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "dist/**", "!.next/cache/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"]
    },
    "lint": {
      "outputs": []
    },
    "worker:start": {
      "cache": false,
      "persistent": true
    }
  }
}
